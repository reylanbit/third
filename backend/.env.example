# Hugging Face – crie um token em `https://huggingface.co/settings/tokens`  (read) 
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx 
 
# Upstash Redis – crie um database em `https://console.upstash.com`  (free tier) 
UPSTASH_REDIS_URL=rediss://default:xxxx@us1-xxxx-xxxx.upstash.io:12345 
 
# Neon PostgreSQL – crie um projeto em `https://neon.tech` 
DATABASE_URL=postgres://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb 
 
# Ambiente de execução 
ENVIRONMENT=development 
LOG_LEVEL=INFO 
